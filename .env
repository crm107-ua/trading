# Copiar a .env y rellenar valores reales. NUNCA commitear .env
# Las claves del exchange deben crearse SIN permiso de retiro (withdrawal)
# y con whitelist de IP en Binance.

# Exchange (Binance spot)
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# API REST del bot (para FreqUI, monitor y scripts auxiliares)
FREQTRADE__API_SERVER__USERNAME=freqtrader
FREQTRADE__API_SERVER__PASSWORD=devpassword_change_me
FREQTRADE__API_SERVER__JWT_SECRET_KEY=devjwtsecretkeyminimum32characters

# Telegram
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# Estrategia activa en dry-run (nombre de clase Python)
STRATEGY=SmokeTestStrategy

# Monitor de riesgo (scripts auxiliares)
MONITOR_DRAWDOWN_PCT=10
MONITOR_API_URL=http://freqtrade:8080
MONITOR_TELEGRAM_TOKEN=
MONITOR_TELEGRAM_CHAT_ID=
