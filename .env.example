# Copiar a .env y rellenar valores reales. NUNCA commitear .env
# Las claves del exchange deben crearse SIN permiso de retiro (withdrawal)
# y con whitelist de IP en Binance.

# Exchange (Binance spot)
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# API REST del bot (para FreqUI, monitor y scripts auxiliares)
FREQTRADE__API_SERVER__USERNAME=freqtrader
FREQTRADE__API_SERVER__PASSWORD=
FREQTRADE__API_SERVER__JWT_SECRET_KEY=

# Telegram
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# Estrategia activa en dry-run (nombre de clase Python)
STRATEGY=SmokeTestStrategy

# Monitor de riesgo (scripts auxiliares)
MONITOR_DRAWDOWN_PCT=10
MONITOR_API_URL=http://freqtrade:8080
MONITOR_TELEGRAM_TOKEN=
MONITOR_TELEGRAM_CHAT_ID=

# Email informes overnight paper (Gmail SMTP / app password)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_TO=caromamusic@gmail.com
MAIL_FROM=
# Desk forever (PM2 poly-desk-forever)
POLY_DESK_MINUTES=12
POLY_DESK_CAPITAL=5
POLY_DESK_CONFIG=maker_demo_promo_pulse_micro5_scalp.json
POLY_DESK_PAUSE_S=45
POLY_DESK_MIN_BALANCE=5
POLY_DESK_EMAIL_EVERY_S=10800

# NVIDIA NIM (polymarket paper)
NVIDIA_API_KEY=
NVIDIA_NIM_MODE=hybrid
NVIDIA_NIM_PROFIT_ASSIST=1

# Polymarket micro-live (NUNCA commitear valores reales)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
POLYMARKET_WALLET_ADDRESS=
POLY_PRIVATE_KEY=
POLY_CLOB_API_KEY=
POLY_CLOB_API_SECRET=
POLY_CLOB_API_PASSPHRASE=
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_RELAYER_HOST=https://relayer-v2.polymarket.com
POLY_CHAIN_ID=137
POLY_LIVE_ARMED=0
POLY_LIVE_DRY_RUN=1
POLY_LIVE_MAX_CAPITAL_USDC=5
POLY_LIVE_CONFIG=polymarket/config/maker_demo_5_eur_t4_micro_live.json
# Tope diario MAX_DAY_LOSS_USDC=5 en código. 1=desactiva el gate (solo temporal).
POLY_LIVE_DAY_LOSS_DISABLE=1

